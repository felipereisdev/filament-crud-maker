{
    "name": "freis/filament-crud-generator",
    "description": "Gerador de CRUD para Filament v4",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Freis\\FilamentCrudGenerator\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Freis\\FilamentCrudGenerator\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Felipe Reis",
            "email": "freis.dev@gmail.com"
        }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "php": "^8.3",
        "filament/filament": "^4.0",
        "laravel/framework": "^11.28|^12.0",
        "friendsofphp/php-cs-fixer": "^3.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^3.0"
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "analyse": "phpstan analyse",
        "cs-fix": [
            "php-cs-fixer fix --config=src/config/php-cs-fixer.dist.php.example"
        ]
    },
    "extra": {
        "laravel": {
            "providers": [
                "Freis\\FilamentCrudGenerator\\Providers\\FilamentCrudGeneratorServiceProvider"
            ]
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
